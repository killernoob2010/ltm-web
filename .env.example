# Supabase PostgreSQL 连接串
# 直接连接 (port 5432) — 本地开发
DATABASE_URL='postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres'

# Session Pooler (port 6543) — 云端部署推荐
# DATABASE_URL='postgresql://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres'

# CORS 允许来源，生产环境必须显式配置，不使用 *
ALLOWED_ORIGINS='https://ltm-web-gt13.onrender.com,https://ltm-web-staging.onrender.com,http://localhost:8000,http://127.0.0.1:8000'

# Session 过期时间
USER_SESSION_TTL_HOURS=168
GUEST_SESSION_TTL_HOURS=8

# 登录失败内存限流。Render 重启后会清空。
LOGIN_FAILURE_LIMIT=5
LOGIN_FAILURE_WINDOW_SECONDS=300

# 轻量后端监控循环预留。当前优先使用现有后端扫描/调度。
ENABLE_MONITORING_LOOP=false
MONITORING_INTERVAL_SECONDS=30
